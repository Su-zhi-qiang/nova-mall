{
	"info": {
		"name": "nova-mall-admin",
		"description": "Nova Mall 后台管理 API 集合（Admin 服务 :8080）",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "认证",
			"item": [
				{
					"name": "登录",
					"request": {
						"method": "POST",
						"url": "{{admin.mall}}/admin/login",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
						}
					}
				},
				{
					"name": "刷新 Token",
					"request": {
						"method": "GET",
						"url": "{{admin.mall}}/admin/refreshToken",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "获取管理员信息",
					"request": {
						"method": "GET",
						"url": "{{admin.mall}}/admin/info",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "退出登录",
					"request": {
						"method": "POST",
						"url": "{{admin.mall}}/admin/logout",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				}
			]
		},
		{
			"name": "商品管理 (PMS)",
			"item": [
				{
					"name": "商品列表",
					"request": {
						"method": "GET",
						"url": "{{admin.mall}}/product/list?pageNum=1&pageSize=10",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "获取全部品牌",
					"request": {
						"method": "GET",
						"url": "{{admin.mall}}/brand/listAll",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "查询一级分类及子分类",
					"request": {
						"method": "GET",
						"url": "{{admin.mall}}/productCategory/list/withChildren",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "批量修改商品删除状态",
					"request": {
						"method": "POST",
						"url": "{{admin.mall}}/product/update/deleteStatus",
						"header": [
							{"key": "Authorization", "value": "Bearer {{token}}"},
							{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{"key": "ids", "value": "1,2"},
								{"key": "deleteStatus", "value": "1"}
							]
						}
					}
				}
			]
		},
		{
			"name": "订单管理 (OMS)",
			"item": [
				{
					"name": "订单列表",
					"request": {
						"method": "GET",
						"url": "{{admin.mall}}/order/list?pageNum=1&pageSize=10",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "退货申请列表",
					"request": {
						"method": "GET",
						"url": "{{admin.mall}}/returnApply/list?pageNum=1&pageSize=10",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				}
			]
		},
		{
			"name": "营销管理 (SMS)",
			"item": [
				{
					"name": "优惠券列表",
					"request": {
						"method": "GET",
						"url": "{{admin.mall}}/coupon/list?pageNum=1&pageSize=10",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "创建优惠券",
					"request": {
						"method": "POST",
						"url": "{{admin.mall}}/coupon/create",
						"header": [
							{"key": "Authorization", "value": "Bearer {{token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"满500减50\",\n  \"type\": 0,\n  \"amount\": 50,\n  \"minPoint\": 500,\n  \"startTime\": \"2026-01-01T00:00:00Z\",\n  \"endTime\": \"2026-12-31T23:59:59Z\",\n  \"enableTime\": \"2026-01-01T00:00:00Z\",\n  \"publishCount\": 100,\n  \"perLimit\": 1,\n  \"useType\": 0,\n  \"platform\": 0,\n  \"note\": \"全场通用满减券\"\n}"
						}
					}
				},
				{
					"name": "秒杀活动列表",
					"request": {
						"method": "GET",
						"url": "{{admin.mall}}/flash/list?pageNum=1&pageSize=10",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "首页广告列表",
					"request": {
						"method": "GET",
						"url": "{{admin.mall}}/home/advertise/list?pageNum=1&pageSize=10",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				}
			]
		},
		{
			"name": "用户管理 (UMS)",
			"item": [
				{
					"name": "管理员列表",
					"request": {
						"method": "GET",
						"url": "{{admin.mall}}/admin/list?pageNum=1&pageSize=10",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "角色列表",
					"request": {
						"method": "GET",
						"url": "{{admin.mall}}/role/list?pageNum=1&pageSize=10",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "资源列表",
					"request": {
						"method": "GET",
						"url": "{{admin.mall}}/resource/list",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				}
			]
		},
		{
			"name": "Agent 查询",
			"item": [
				{
					"name": "销售统计",
					"request": {
						"method": "GET",
						"url": "{{admin.mall}}/agent/stats/sales?days=7",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "热销商品",
					"request": {
						"method": "GET",
						"url": "{{admin.mall}}/agent/stats/top-products?limit=10",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "库存预警",
					"request": {
						"method": "GET",
						"url": "{{admin.mall}}/agent/stats/inventory-alert?threshold=10",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				}
			]
		}
	]
}
