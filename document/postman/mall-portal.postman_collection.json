{
	"info": {
		"name": "nova-mall-portal",
		"description": "Nova Mall 商城前台 API 集合（Portal 服务 :8085）",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "认证",
			"item": [
				{
					"name": "会员登录",
					"request": {
						"method": "POST",
						"url": "{{portal.mall}}/sso/login",
						"header": [{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{"key": "username", "value": "test"},
								{"key": "password", "value": "123456"}
							]
						}
					}
				},
				{
					"name": "获取会员信息",
					"request": {
						"method": "GET",
						"url": "{{portal.mall}}/sso/info",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				}
			]
		},
		{
			"name": "首页",
			"item": [
				{
					"name": "首页内容",
					"request": {
						"method": "GET",
						"url": "{{portal.mall}}/home/content"
					}
				},
				{
					"name": "秒杀活动",
					"request": {
						"method": "GET",
						"url": "{{portal.mall}}/home/flashPromotion"
					}
				},
				{
					"name": "新品推荐",
					"request": {
						"method": "GET",
						"url": "{{portal.mall}}/home/newProductList"
					}
				},
				{
					"name": "热销商品",
					"request": {
						"method": "GET",
						"url": "{{portal.mall}}/home/hotProductList"
					}
				}
			]
		},
		{
			"name": "商品",
			"item": [
				{
					"name": "商品搜索",
					"request": {
						"method": "GET",
						"url": "{{portal.mall}}/product/search?keyword=手机&pageNum=1&pageSize=10"
					}
				},
				{
					"name": "商品详情",
					"request": {
						"method": "GET",
						"url": "{{portal.mall}}/product/detail/26"
					}
				},
				{
					"name": "品牌推荐列表",
					"request": {
						"method": "GET",
						"url": "{{portal.mall}}/brand/recommendList"
					}
				}
			]
		},
		{
			"name": "购物车",
			"item": [
				{
					"name": "添加购物车",
					"request": {
						"method": "POST",
						"url": "{{portal.mall}}/cart/add",
						"header": [
							{"key": "Authorization", "value": "Bearer {{token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"productId\": 26,\n  \"quantity\": 1\n}"
						}
					}
				},
				{
					"name": "购物车列表",
					"request": {
						"method": "GET",
						"url": "{{portal.mall}}/cart/list",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "修改购物车数量",
					"request": {
						"method": "GET",
						"url": "{{portal.mall}}/cart/update/quantity?id=1&quantity=2",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "删除购物车商品",
					"request": {
						"method": "POST",
						"url": "{{portal.mall}}/cart/delete",
						"header": [
							{"key": "Authorization", "value": "Bearer {{token}}"},
							{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [{"key": "ids", "value": "1"}]
						}
					}
				},
				{
					"name": "清空购物车",
					"request": {
						"method": "POST",
						"url": "{{portal.mall}}/cart/clear",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				}
			]
		},
		{
			"name": "订单",
			"item": [
				{
					"name": "生成确认单",
					"request": {
						"method": "POST",
						"url": "{{portal.mall}}/order/generateConfirmOrder",
						"header": [
							{"key": "Authorization", "value": "Bearer {{token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"cartIds\": [1]\n}"
						}
					}
				},
				{
					"name": "下单",
					"request": {
						"method": "POST",
						"url": "{{portal.mall}}/order/generateOrder",
						"header": [
							{"key": "Authorization", "value": "Bearer {{token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"cartIds\": [1],\n  \"memberReceiveAddressId\": 1,\n  \"payType\": 1\n}"
						}
					}
				},
				{
					"name": "订单列表",
					"request": {
						"method": "GET",
						"url": "{{portal.mall}}/order/list?status=0&pageNum=1&pageSize=10",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "订单详情",
					"request": {
						"method": "GET",
						"url": "{{portal.mall}}/order/detail/1",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "取消订单",
					"request": {
						"method": "POST",
						"url": "{{portal.mall}}/order/cancelOrder?orderId=1",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "确认收货",
					"request": {
						"method": "POST",
						"url": "{{portal.mall}}/order/confirmReceiveOrder?orderId=1",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "支付回调",
					"request": {
						"method": "POST",
						"url": "{{portal.mall}}/order/paySuccess?orderId=1",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				}
			]
		},
		{
			"name": "优惠券",
			"item": [
				{
					"name": "可领取优惠券",
					"request": {
						"method": "GET",
						"url": "{{portal.mall}}/member/coupon/available"
					}
				},
				{
					"name": "领取优惠券",
					"request": {
						"method": "POST",
						"url": "{{portal.mall}}/member/coupon/add/1",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "我的优惠券列表",
					"request": {
						"method": "GET",
						"url": "{{portal.mall}}/member/coupon/list",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				}
			]
		},
		{
			"name": "收货地址",
			"item": [
				{
					"name": "地址列表",
					"request": {
						"method": "GET",
						"url": "{{portal.mall}}/member/address/list",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "新增地址",
					"request": {
						"method": "POST",
						"url": "{{portal.mall}}/member/address/add",
						"header": [
							{"key": "Authorization", "value": "Bearer {{token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"张三\",\n  \"phoneNumber\": \"13800138000\",\n  \"province\": \"广东省\",\n  \"city\": \"深圳市\",\n  \"region\": \"南山区\",\n  \"detailAddress\": \"科技园路1号\",\n  \"defaultStatus\": 0\n}"
						}
					}
				},
				{
					"name": "删除地址",
					"request": {
						"method": "POST",
						"url": "{{portal.mall}}/member/address/delete/1",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				}
			]
		},
		{
			"name": "售后",
			"item": [
				{
					"name": "售后申请列表",
					"request": {
						"method": "GET",
						"url": "{{portal.mall}}/returnApply/list?pageNum=1&pageSize=10",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
					}
				},
				{
					"name": "申请退货",
					"request": {
						"method": "POST",
						"url": "{{portal.mall}}/returnApply/create",
						"header": [
							{"key": "Authorization", "value": "Bearer {{token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"orderId\": 1,\n  \"returnAmount\": 100.00,\n  \"returnName\": \"退货退款\",\n  \"returnPhone\": \"13800138000\",\n  \"reason\": \"不想要了\",\n  \"description\": \"拍错了\"\n}"
						}
					}
				}
			]
		}
	]
}
