<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.su.mall.dao.PmsProductCategoryDao">
    <resultMap id="listWithChildrenMap" type="com.su.mall.dto.PmsProductCategoryWithChildrenItem" autoMapping="true">
        <id column="id" property="id"/>
        <!-- 父类 PmsProductCategory 字段由 autoMapping 自动映射，删除冗余 <result> -->
        <collection property="children" columnPrefix="child_" ofType="com.su.mall.model.PmsProductCategory" autoMapping="true">
            <id column="id" property="id"/>
            <!-- 子分类字段由 autoMapping 自动映射 -->
        </collection>
    </resultMap>
    <select id="listWithChildren" resultMap="listWithChildrenMap">
        select
            c1.id,
            c1.name,
            c2.id   child_id,
            c2.name child_name
        from pms_product_category c1 left join pms_product_category c2 on c1.id = c2.parent_id
        where c1.parent_id = 0
    </select>
</mapper>
