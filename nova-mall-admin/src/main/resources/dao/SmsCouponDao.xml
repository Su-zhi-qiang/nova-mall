<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.su.mall.dao.SmsCouponDao">
    <resultMap id="couponItemParam" type="com.su.mall.dto.SmsCouponParam" autoMapping="true">
        <id column="id" jdbcType="BIGINT" property="id"/>
        <!-- 父类 SmsCoupon 字段由 autoMapping 自动映射，删除所有冗余 <result> -->
        <collection property="productRelationList" columnPrefix="cpr_" ofType="com.su.mall.model.SmsCouponProductRelation" autoMapping="true">
            <id column="id" property="id"/>
            <!-- 优惠券商品关联字段由 autoMapping 自动映射 -->
        </collection>
        <collection property="productCategoryRelationList" columnPrefix="cpcr_" ofType="com.su.mall.model.SmsCouponProductCategoryRelation" autoMapping="true">
            <id column="id" property="id"/>
            <!-- 优惠券分类关联字段由 autoMapping 自动映射 -->
        </collection>
    </resultMap>
    <select id="getItem" resultMap="couponItemParam">
        SELECT
            c.*,
            cpr.id                   cpr_id,
            cpr.product_id           cpr_product_id,
            cpr.product_name         cpr_product_name,
            cpr.product_sn           cpr_product_sn,
            cpcr.id                  cpcr_id,
            cpcr.product_category_id cpcr_product_category_id,
            cpcr.product_category_name cpcr_product_category_name,
            cpcr.parent_category_name cpcr_parent_category_name
        FROM
            sms_coupon c
            LEFT JOIN sms_coupon_product_relation cpr ON c.id = cpr.coupon_id
            LEFT JOIN sms_coupon_product_category_relation cpcr ON c.id = cpcr.coupon_id
        WHERE
            c.id = #{id}
    </select>
</mapper>
