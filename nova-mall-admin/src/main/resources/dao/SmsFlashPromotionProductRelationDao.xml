<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.su.mall.dao.SmsFlashPromotionProductRelationDao">
    <resultMap id="flashProductMap" type="com.su.mall.dto.SmsFlashPromotionProduct">
        <id column="id" property="id"/>
        <result column="flash_promotion_price" property="flashPromotionPrice"/>
        <result column="flash_promotion_count" property="flashPromotionCount"/>
        <result column="original_count" property="originalCount"/>
        <result column="flash_promotion_sold" property="flashPromotionSold"/>
        <result column="flash_promotion_limit" property="flashPromotionLimit"/>
        <result column="flash_promotion_id" property="flashPromotionId"/>
        <result column="flash_promotion_session_id" property="flashPromotionSessionId"/>
        <result column="product_id" property="productId"/>
        <result column="sort" property="sort"/>
        <association property="product" javaType="com.su.mall.model.PmsProduct">
            <id column="p_id" property="id"/>
            <result column="p_name" property="name"/>
            <result column="p_product_sn" property="productSn"/>
            <result column="p_price" property="price"/>
            <result column="p_stock" property="stock"/>
        </association>
    </resultMap>
    <select id="getList" resultMap="flashProductMap">
        SELECT
            r.id,
            r.flash_promotion_price,
            r.flash_promotion_count,
            r.original_count,
            r.flash_promotion_sold,
            r.flash_promotion_limit,
            r.flash_promotion_id,
            r.flash_promotion_session_id,
            r.product_id,
            r.sort,
            p.id p_id,
            p.`name` p_name,
            p.product_sn p_product_sn,
            p.price p_price,
            p.stock p_stock
        FROM
            sms_flash_promotion_product_relation r
            LEFT JOIN pms_product p ON r.product_id = p.id
        <where>
            <if test="flashPromotionId != null">
                AND r.flash_promotion_id = #{flashPromotionId}
            </if>
            <if test="flashPromotionSessionId != null">
                AND r.flash_promotion_session_id = #{flashPromotionSessionId}
            </if>
        </where>
        ORDER BY r.sort DESC
    </select>
</mapper>
