<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.su.mall.dao.PmsProductAttributeCategoryDao">
    <resultMap id="getListWithAttrMap" type="com.su.mall.dto.PmsProductAttributeCategoryItem" autoMapping="true">
        <id column="id" property="id"/>
        <!-- 父类 PmsProductAttributeCategory 字段由 autoMapping 自动映射，删除冗余 <result> -->
        <collection property="productAttributeList" columnPrefix="attr_" ofType="com.su.mall.model.PmsProductAttribute" autoMapping="true">
            <id column="id" property="id"/>
            <!-- 商品属性字段由 autoMapping 自动映射 -->
        </collection>
    </resultMap>
    <select id="getListWithAttr" resultMap="getListWithAttrMap">
        SELECT
            pac.id,
            pac.name,
            pa.id attr_id,
            pa.name attr_name
        FROM
            pms_product_attribute_category pac
            LEFT JOIN pms_product_attribute pa ON pac.id = pa.product_attribute_category_id
        AND pa.type=1;
    </select>
</mapper>
